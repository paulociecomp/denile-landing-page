---
import Header from '../components/Header.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Seiva Sana | Cuidado Médico Integrativo com Dra. Denile Oliveira' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth overflow-x-hidden">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Inter:wght@300;400;500;700&family=Great+Vibes&display=swap" rel="stylesheet">
		<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
		<meta name="description" content="Recupere sua qualidade de vida com a Dra. Denile Oliveira. Cuidado médico integrativo, seguro e personalizado para saúde e bem-estar." />
		<meta name="keywords" content="medicina integrativa, saúde, bem-estar, tratamento natural, Dra. Denile Oliveira, cuidado médico, clínica, consulta, qualidade de vida" />
		<meta name="author" content="Dra. Denile Oliveira" />
		<meta property="og:title" content="Seiva Sana - Cuidado Médico Integrativo com Dra. Denile Oliveira" />
		<meta property="og:description" content="Cuidado médico integrativo, seguro e personalizado. Recupere sua esperança de viver com acompanhamento médico especializado." />
		<meta property="og:image" content="https://seivasana.com.br/images/denile_bk2.png" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://seivasana.com.br/" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Seiva Sana - Cuidado Médico Integrativo com Dra. Denile Oliveira" />
		<meta name="twitter:description" content="Cuidado médico integrativo, seguro e personalizado. Recupere sua esperança de viver com acompanhamento médico especializado." />
		<meta name="twitter:image" content="https://seivasana.com.br/images/denile_bk2.png" />
		<link rel="canonical" href="https://seivasana.com.br/" />
	</head>
	<body class="antialiased bg-gray-50 overflow-x-hidden">
		<Header />
		<main>
			<slot />
		</main>
		<CookieBanner />
	</body>
</html>

<style is:global>
	:root {
		--font-serif: 'Cormorant Garamond', serif;
		--font-sans: 'Inter', 'Lato', 'Open Sans', sans-serif;
		--font-cursive: 'Great Vibes', cursive;
	}

	html {
		font-family: var(--font-sans);
		font-size: 18px;
		line-height: 1.7;
		color: #4F4A45;
		background-color: #F7F4EE;
	}

	.font-serif {
		font-family: var(--font-serif);
		font-weight: 600;
	}

	.font-cursive {
		font-family: var(--font-cursive);
	}
</style>
