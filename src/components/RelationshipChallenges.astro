---
const symptoms = [
  {
    title: "Dificuldade para dormir",
    description: "O sistema endocanabinoide participa da regulação do ciclo sono-vigília e do relaxamento físico, podendo auxiliar na qualidade do sono e nos despertares noturnos.",
    note: "¹",
    icon: "moon",
  },
  {
    title: "Ansiedade e mente acelerada",
    description: "A modulação de receptores CB1 está associada a mecanismos relacionados ao estresse, resposta emocional e hiperativação mental.",
    note: "²",
    icon: "bolt",
  },
  {
    title: "Humor e exaustão emocional",
    description: "A sinalização endocanabinoide participa de processos ligados à motivação, neuroplasticidade e regulação emocional.",
    note: "³",
    icon: "sun",
  },
  {
    title: "Alterações de apetite",
    description: "O sistema endocanabinoide influencia mecanismos relacionados ao apetite, metabolismo energético e recompensa alimentar.",
    note: "⁴",
    icon: "scale",
  },
  {
    title: "Dor e tensão muscular",
    description: "Canabinoides interagem com vias neuroinflamatórias envolvidas na modulação da dor e da tensão muscular persistente.",
    note: "⁵",
    icon: "fire",
  },
  {
    title: "Sono não reparador e fadiga",
    description: "A regulação endocanabinoide está associada a processos de recuperação fisiológica e qualidade do descanso.",
    note: "⁶",
    icon: "battery",
  },
];
---
<section id="desafios" class="py-20 bg-bg-light scroll-mt-24">
  <div class="container mx-auto px-4 relative">
    <h2 class="text-3xl font-serif font-semibold text-center mb-16 text-primary">
      Sintomas e condições em que a cannabis medicinal pode auxiliar:
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      {symptoms.map((s) => (
        <div class="bg-[#FAF8F4] border border-[#E7DFD1] rounded-3xl shadow-sm p-6 hover:shadow-md hover:-translate-y-0.5 transition duration-200 flex items-start gap-4 h-full">
          <div class="shrink-0 inline-flex items-center justify-center bg-gold/30 rounded-full p-3 mt-1">
            {s.icon === "moon" && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-primary">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
              </svg>
            )}
            {s.icon === "bolt" && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-primary">
                <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
              </svg>
            )}
            {s.icon === "sun" && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-primary">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
              </svg>
            )}
            {s.icon === "scale" && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-primary">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z" />
              </svg>
            )}
            {s.icon === "fire" && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-primary">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.467 5.99 5.99 0 0 0-1.925 3.547 5.974 5.974 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" />
              </svg>
            )}
            {s.icon === "battery" && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-primary">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M4.5 18.75h11.25c1.243 0 2.25-1.007 2.25-2.25V7.5c0-1.243-1.007-2.25-2.25-2.25H4.5C3.257 5.25 2.25 6.257 2.25 7.5v9c0 1.243 1.007 2.25 2.25 2.25Z" />
              </svg>
            )}
          </div>
          <div>
            <h3 class="text-primary font-semibold text-xl mb-3 font-serif text-balance">{s.title}</h3>
            <p class="text-text-main font-sans text-sm leading-relaxed">
              {s.description}<sup class="text-[10px] font-semibold ml-0.5" style="color:#B5673A">{s.note}</sup>
            </p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-xs text-text-main/60 font-sans text-center mt-16 max-w-2xl mx-auto pt-6 border-t border-gold/30">
      ¹–⁶ Baseado em evidências científicas contemporâneas sobre o sistema endocanabinoide.
    </p>
  </div>
</section>
