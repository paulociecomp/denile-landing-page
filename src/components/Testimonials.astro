---
const testimonials = [
  {
    quote: "Passei a dormir melhor e me sentir mais estável emocionalmente durante o acompanhamento.",
    name: "L.S., 45 anos",
    context: "em acompanhamento para insônia e dor crônica",
  },
  {
    quote: "O tratamento me ajudou a reduzir a ansiedade sem perder clareza mental ao longo do dia.",
    name: "V.M., 30 anos",
    context: "em acompanhamento regular",
  },
  {
    quote: "Consegui integrar o acompanhamento clínico médico a outros cuidados terapêuticos, obtendo grandes melhorias.",
    name: "P.I., 27 anos",
    context: "em acompanhamento multidisciplinar",
  },
  {
    quote: "Senti melhora na disposição física e na qualidade do descanso após os ajustes terapêuticos.",
    name: "R.C., 52 anos",
    context: "em acompanhamento para dores persistentes",
  },
  {
    quote: "O acolhimento e a escuta durante as consultas fizeram diferença no meu processo de cuidado.",
    name: "A.M., 38 anos",
    context: "em acompanhamento para ansiedade",
  },
];

const positions = [
  "lg:col-span-2",
  "lg:col-span-2",
  "lg:col-span-2",
  "lg:col-span-2 lg:col-start-2",
  "lg:col-span-2",
];
---

<section id="depoimentos" class="py-20 scroll-mt-24" style="background:#F5F1E8">
  <div class="container mx-auto px-4">
    <h2 class="font-serif font-semibold text-3xl md:text-4xl text-center mb-12 leading-tight tracking-tight" style="color:#556245">
      Relatos de quem passou pelo acompanhamento
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-x-6 gap-y-8 max-w-6xl mx-auto items-stretch">
      {testimonials.map((t, i) => (
        <article
          class={`relative rounded-3xl border border-[#E7DFD1] p-5 lg:p-6 shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_4px_20px_rgba(0,0,0,0.07)] hover:-translate-y-0.5 transition-[box-shadow,transform] duration-200 h-full flex flex-col ${positions[i]}`}
          style="background:#FAF8F4"
        >
          <span class="absolute top-4 left-5 text-6xl font-serif leading-none select-none" style="color:rgba(201,207,191,0.45)" aria-hidden="true">❝</span>
          <p class="font-serif text-base leading-relaxed relative z-10 flex-1" style="color:#2F312D">
            {t.quote}
          </p>
          <p class="mt-5 font-sans font-medium text-sm" style="color:#556245">{t.name}</p>
          <p class="font-sans font-normal text-xs mt-1" style="color:#7B776F">{t.context}</p>
        </article>
      ))}
    </div>
  </div>
</section>
