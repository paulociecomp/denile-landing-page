---
import { Image } from 'astro:assets';
---
<section class="min-h-[85vh] relative overflow-hidden bg-bg-light" x-data="{ y: 0 }" x-init="window.addEventListener('scroll', () => { y = window.scrollY })">
  <!-- Background image com parallax -->
  <div class="absolute inset-0 will-change-transform" :style="`transform: translateY(${y * 0.3}px);`">
    <img
      src="/images/denile_bk1.png"
      alt="Consultório Seiva Sana - Cuidado médico integrativo"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-bg-dark opacity-70"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 pt-[128px] pb-12 md:px-8 md:pt-[120px] md:pb-14 flex flex-col md:flex-row items-center gap-8 md:gap-12">
    <!-- Left column -->
    <div class="flex-1 text-center md:text-left">
      <h1 class="font-serif text-3xl md:text-5xl text-white leading-tight drop-shadow-lg">
        Cuidado médico integrativo com<br class="hidden md:block" /> atendimento personalizado
      </h1>

      <p class="mt-6 md:mt-8 text-base md:text-lg text-white max-w-[560px] mx-auto md:mx-0 font-sans">
        Avaliação médica individualizada com foco em bem-estar e acompanhamento integrado.
      </p>

      <div class="pt-8 flex justify-center md:justify-start">
        <a
          href="https://wa.me/5511943230906"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-10 py-4 rounded-full bg-accent text-white text-base font-semibold shadow-[0_4px_20px_rgba(201,130,106,0.4)] hover:shadow-[0_6px_28px_rgba(201,130,106,0.55)] hover:-translate-y-0.5 transition-all duration-200"
        >
          Agendar avaliação
        </a>
      </div>

    </div>

    <!-- Right column -->
    <div class="flex-1 relative w-full">
      <div class="w-full max-w-[260px] mx-auto md:max-w-[380px] md:ml-auto">
        <div class="aspect-[3/4] rounded-[100px] overflow-hidden border-2 border-gold">
          <Image
            src="/images/denile_hero.jpg"
            alt="Dra. Denile Oliveira"
            width={450}
            height={600}
            class="w-full h-full object-cover"
          />
        </div>
        <div class="mt-4 text-center">
          <p class="font-serif text-lg text-gold">Dra. Denile Oliveira</p>
          <p class="font-sans text-sm text-white/70 tracking-wide uppercase mt-1">Médica | Idealizadora da Seiva Sana</p>
        </div>
      </div>
    </div>
  </div>
</section>
