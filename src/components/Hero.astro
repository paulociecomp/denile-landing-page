---
import { Image } from 'astro:assets';
---
<section class="min-h-[80vh] relative overflow-hidden bg-bg-light" x-data="{ y: 0 }" x-init="window.addEventListener('scroll', () => { y = window.scrollY })">
  <!-- Background image com parallax -->
  <div class="absolute inset-0 will-change-transform" :style="`transform: translateY(${y * 0.3}px);`">
    <img
      src="/images/denile_bk1.png"
      alt="Background"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-bg-dark opacity-70"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 pt-32 pb-20 md:px-8 md:pt-32 md:pb-32 flex flex-col md:flex-row items-center gap-8 md:gap-12">
    <!-- Left column -->
    <div class="flex-1 text-center md:text-left">
      <h1 class="font-serif text-3xl md:text-5xl text-white leading-snug drop-shadow-lg">
        Tratamento com Cannabis Medicinal<br class="hidden md:block" /> de forma segura, ética e personalizada.
      </h1>

      <p class="mt-6 md:mt-8 text-base md:text-lg text-white max-w-lg mx-auto md:mx-0 font-sans">
        Avaliação médica individualizada para prescrição responsável de cannabis medicinal e acompanhamento terapêutico integrado.
      </p>

      <div class="pt-8 flex justify-center md:justify-start">
        <a
          href="https://wa.me/5511943230906"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-10 py-4 rounded-full bg-accent text-white text-base font-semibold shadow-[0_4px_20px_rgba(201,130,106,0.4)] hover:shadow-[0_6px_28px_rgba(201,130,106,0.55)] hover:-translate-y-0.5 transition-all duration-200"
        >
          Agendar avaliação
        </a>
      </div>

      <div class="pt-8">
        <p class="font-cursive text-2xl text-gold">Dr. Denile Oliveira</p>
      </div>
    </div>

    <!-- Right column -->
    <div class="flex-1 relative w-full">
      <div class="w-full max-w-xs mx-auto md:max-w-none">
        <div class="aspect-[3/4] rounded-[120px] overflow-hidden border-2 border-gold">
          <Image
            src="/images/denile_bk2.png"
            alt="Dra. Denile Oliveira"
            width={600}
            height={800}
            class="w-full h-full object-cover"
          />
        </div>
        <div class="mt-4 text-center">
          <p class="font-serif text-lg text-gold">Dra. Denile Oliveira</p>
          <p class="font-sans text-sm text-white/70 tracking-wide uppercase mt-1">Médica | Idealizadora da Seiva Sana</p>
        </div>
      </div>
    </div>
  </div>
</section>
