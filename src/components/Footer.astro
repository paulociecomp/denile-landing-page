---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 font-sans" style="background:#4A5540">
  <div class="container mx-auto px-4 flex flex-col items-center gap-6">
    <a
      href="https://instagram.com/seivasana"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram @seivasana"
      class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-white/30 text-white/90 hover:bg-white/10 transition-colors text-sm"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3.75h10.5a3 3 0 0 1 3 3v10.5a3 3 0 0 1-3 3H6.75a3 3 0 0 1-3-3V6.75a3 3 0 0 1 3-3Z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 7.5h.008v.008H16.5V7.5Z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
      </svg>
      <span>@seivasana</span>
    </a>
    <p class="text-xs text-white/60">&copy; {currentYear} Seiva Sana — Todos os direitos reservados.</p>
  </div>
</footer>
