<div
  x-data="{ show: false }"
  x-init="if (!localStorage.getItem('seiva-sana-cookies')) { setTimeout(() => show = true, 600) }"
  x-show="show"
  x-cloak
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0 translate-y-4"
  x-transition:enter-end="opacity-100 translate-y-0"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100 translate-y-0"
  x-transition:leave-end="opacity-0 translate-y-4"
  class="fixed bottom-4 left-4 right-4 md:left-auto md:right-4 md:max-w-md z-50 rounded-2xl border border-[#E7DFD1] shadow-[0_8px_24px_rgba(0,0,0,0.08)] p-5"
  style="background:#F5F1EA;color:#4F4A45"
  role="dialog"
  aria-label="Aviso de cookies"
>
  <p class="font-sans text-sm leading-relaxed">
    Utilizamos cookies para melhorar sua experiência, analisar o tráfego do site e personalizar conteúdos relacionados ao acompanhamento terapêutico. Ao continuar navegando, você concorda com nossa
    <a href="/politica-de-privacidade" class="underline underline-offset-2 hover:opacity-80" style="color:#4A5540">Política de Privacidade</a>
    e uso de cookies.
  </p>
  <div class="mt-4 flex justify-end">
    <button
      type="button"
      class="inline-block rounded-2xl px-5 py-2 font-sans text-sm font-semibold transition-colors"
      style="background:#D9896A;color:#F8F5EF"
      onmouseover="this.style.background='#C97958'"
      onmouseout="this.style.background='#D9896A'"
      x-on:click="localStorage.setItem('seiva-sana-cookies', 'accepted'); show = false"
    >
      Aceitar
    </button>
  </div>
</div>
