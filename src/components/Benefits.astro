---
const benefits = [
  { label: "Sono reparador", description: "Melhora da qualidade do descanso e recuperação física.", icon: "moon" },
  { label: "Clareza mental", description: "Maior foco e organização nas atividades do cotidiano.", icon: "bulb" },
  { label: "Equilíbrio emocional", description: "Redução da sobrecarga mental e melhora do bem-estar emocional.", icon: "scale" },
  { label: "Bem-estar físico", description: "Manejo mais confortável de dores persistentes e tensões musculares.", icon: "heart" },
  { label: "Qualidade de vida", description: "Mais disposição para atividades cotidianas e autocuidado.", icon: "sun" },
  { label: "Redução medicamentosa", description: "Possível redução da sobrecarga medicamentosa, quando clinicamente indicado.", icon: "beaker", italic: true },
];
---
<section id="beneficios" class="relative py-20 bg-bg-light scroll-mt-24">
  <div class="bg-[#D9DFCF] text-[#3A4030] py-8 px-8 rounded-2xl max-w-6xl mx-auto -mt-32 mb-32 relative z-10 shadow-xl">
    <div class="border border-[#B5BDA8] p-6 rounded-xl">
      <h2 class="text-2xl font-light text-center leading-relaxed max-w-[700px] mx-auto font-sans">
        Um cuidado clínico humanizado e individualizado, que acolhe o paciente de forma completa e promove mais equilíbrio, bem-estar e qualidade de vida.
      </h2>
      <div class="text-center mt-8">
        <a
          href="https://wa.me/5511943230906"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-[#D9896A] text-white rounded-full px-8 py-3.5 font-sans font-medium hover:bg-[#C97859] transition-colors"
        >
          Iniciar acompanhamento
        </a>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-12 gap-4 items-start">
      <div class="md:col-span-5">
        <h2 class="text-4xl font-serif font-semibold text-primary leading-tight">
          Possíveis benefícios percebidos ao longo do acompanhamento.
        </h2>
      </div>

      <div class="md:col-span-7">
        <div class="bg-[#FAF8F4] border border-[#E7DFD1] rounded-3xl shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_4px_20px_rgba(0,0,0,0.07)] transition-shadow duration-200 p-8">
          <ul>
            {benefits.map((b, idx) => (
              <>
                {idx > 0 && <div class="border-t border-[#E7DFD1] mx-4"></div>}
                <li class="py-5 first:pt-0 last:pb-0 flex items-start gap-3">
                  <span class="shrink-0 mt-1 text-primary">
                    {b.icon === "moon" && (
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
                      </svg>
                    )}
                    {b.icon === "bulb" && (
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                      </svg>
                    )}
                    {b.icon === "scale" && (
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z" />
                      </svg>
                    )}
                    {b.icon === "heart" && (
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                      </svg>
                    )}
                    {b.icon === "sun" && (
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
                      </svg>
                    )}
                    {b.icon === "beaker" && (
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                      </svg>
                    )}
                  </span>
                  <div>
                    <h3 class="text-lg font-bold font-serif text-primary leading-snug">{b.label}</h3>
                    <p class={`text-sm leading-relaxed font-sans mt-1.5 ${b.italic ? 'italic text-text-main/60' : 'text-text-main/80'}`}>{b.description}</p>
                  </div>
                </li>
              </>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
